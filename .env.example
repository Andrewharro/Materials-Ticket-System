# Database
DATABASE_URL=postgresql://materials:materials_password@localhost:5432/materials_os

# Authentication
JWT_SECRET=change-me-to-a-random-secret-string

# Application
APP_BASE_URL=http://localhost:5000
PORT=5000
NODE_ENV=development

# SMTP / Email Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# Coordinator group email (receives ticket notifications)
COORDINATOR_GROUP_EMAIL=coordinators@example.com
